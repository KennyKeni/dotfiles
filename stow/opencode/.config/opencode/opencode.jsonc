{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "agent": {
    "build": {
      "disable": false,
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "context7_resolve-library-id": "deny",
        "context7_query-docs": "deny"
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "disable": false,
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "context7_resolve-library-id": "deny",
        "context7_query-docs": "deny"
      }
    }
  },
  "lsp": true
}
